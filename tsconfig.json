{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "baseUrl": ".", 
    "types": [
      "jest"
    ],
    "paths": {
      "@/*": ["src/*"],
      "tailwind.config": ["./tailwind.config.js"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "**/*.ts",
    "**/*.tsx",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "ios/Pods"
  ]
}